{
    "name": "shipmonk/packing",
    "description": "Testing day application stub",
    "version": "1.0.0",
    "require": {
        "ext-pdo": "*",
        "ext-json": "*",
        "php": ">=8.4",
        "psr/http-message": "2.*",
        "guzzlehttp/psr7": "2.*",
        "doctrine/orm": "3.*",
        "symfony/cache": "7.*",
        "guzzlehttp/guzzle": "^7.9",
        "symfony/validator": "^8.0",
        "ackintosh/ganesha": "^4.0",
        "symfony/serializer": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^7.4",
        "symfony/dotenv": "^8.0",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "vimeo/psalm": "^6.15",
        "friendsofphp/php-cs-fixer": "^3.75",
        "infection/infection": "^0.32"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "cs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --dry-run --diff",
        "cs:fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix",
        "stan": "phpstan analyse --memory-limit=512M",
        "psalm": "psalm --no-cache",
        "test": "phpunit",
        "infection": "infection --threads=max"
    }
}
