{
  "$schema": "https://raw.githubusercontent.com/infection/infection/0.32.6/resources/schema.json",
  "minMsi": 80.0,
  "minCoveredMsi": 80.0,
  "source": {
    "directories": [
      "src"
    ]
  },
  "phpUnit": {
    "configDir": "."
  },
  "logs": {
    "summary": "build/infection-summary.log"
  },
  "mutators": {
    "@default": true
  }
}
