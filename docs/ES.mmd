  subgraph L[Legend]
    LA[Actor]:::actor
    LC[Command]:::command
    LE[Domain Event]:::event
    LP[Policy]:::policy
    LS[(External System)]:::system
    LM[[Read Model / Projection]]:::model
  end

  A[Cart / Checkout]:::actor
  API[(3DBinPacking API)]:::system
