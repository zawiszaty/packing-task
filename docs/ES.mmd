flowchart LR
  classDef actor fill:#ffe082,stroke:#8d6e63,color:#111;
  classDef command fill:#90caf9,stroke:#1565c0,color:#111;
  classDef event fill:#ffcc80,stroke:#ef6c00,color:#111;
  classDef policy fill:#ce93d8,stroke:#6a1b9a,color:#111;
  classDef system fill:#a5d6a7,stroke:#2e7d32,color:#111;
